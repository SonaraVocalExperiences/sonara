---
// English — served at /en
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import VideoSection from '../../components/VideoSection.astro';
import Approach from '../../components/Approach.astro';
import Testimonials from '../../components/Testimonials.astro';
import Contact from '../../components/Contact.astro';
import Marquee from '../../components/Marquee.astro';
import Footer from '../../components/Footer.astro';
import content from '../../content/home/en.json';
---

<Layout lang="en">
  <Nav locale="en" approachLabel={content.nav.approach} contactLabel={content.nav.contact} />
  <Hero {...content.hero} />
  <VideoSection url={content.video.url} />
  <Approach {...content.approach} />
  <Testimonials items={content.testimonials} />
  <Contact {...content.contact} />
  <Marquee text={content.footer.marqueeText} />
  <Footer email={content.contact.email} phone={content.contact.phone} copyright={content.footer.copyright} />
</Layout>
