---
import '../styles/global.css';
import { VisualEditing } from '@sanity/astro/visual-editing';
import { isPreviewRequest } from '../lib/sanity/preview';

interface Props {
  title?: string;
  lang: string;
}

const { title = 'Sonara — Vocal Experiences for Wellbeing', lang } = Astro.props;
const visualEditingEnabled = isPreviewRequest(Astro.cookies);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Sonara — Vocal Experiences for Wellbeing" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-cream text-dark font-sans antialiased">
    <slot />
    <VisualEditing enabled={visualEditingEnabled} />
  </body>
</html>
