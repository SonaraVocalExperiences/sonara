---
interface Props {
  heading: string;
  body: string;
  formHeading: string;
  formBody: string;
  labelName: string;
  labelOrg: string;
  labelEmail: string;
  labelMessage: string;
  submitText: string;
  email: string;
  phone: string;
  linkedinUrl: string;
  labelWorkshops: string;
  labelDirect: string;
  labelLinkedin: string;
}

const props = Astro.props;
---

<section id="contacto" class="bg-cream py-24 px-6">
  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
    <!-- Left: CTA text + contact info -->
    <div>
      <h2 class="text-4xl md:text-5xl font-black text-dark leading-tight mb-6">{props.heading}</h2>
      <p class="text-base text-dark/80 leading-relaxed mb-12">{props.body}</p>
      <hr class="border-dark/20 mb-10" />
      <div class="grid grid-cols-2 gap-8">
        <div>
          <p class="text-xs font-bold tracking-widest text-dark/50 mb-2">{props.labelWorkshops}</p>
          <a href={`mailto:${props.email}`} class="text-sm font-medium text-dark break-all hover:underline">
            {props.email}
          </a>
        </div>
        <div>
          <p class="text-xs font-bold tracking-widest text-dark/50 mb-2">{props.labelDirect}</p>
          <a href={`tel:${props.phone.replace(/\s/g, '')}`} class="text-sm font-medium text-dark hover:underline">
            {props.phone}
          </a>
        </div>
        <div>
          <p class="text-xs font-bold tracking-widest text-dark/50 mb-2">{props.labelLinkedin}</p>
          <a href={props.linkedinUrl} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <!-- LinkedIn icon -->
            <svg class="w-7 h-7 text-[#0077B5] fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Right: Contact form -->
    <div class="bg-sage rounded-2xl p-8">
      <h3 class="text-xl font-semibold text-dark mb-2">{props.formHeading}</h3>
      <p class="text-sm text-dark/70 leading-relaxed mb-6">{props.formBody}</p>
      <form name="contact" method="POST" data-netlify="true" class="space-y-4">
        <input type="hidden" name="form-name" value="contact" />
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-medium text-dark mb-1">{props.labelName}</label>
            <input
              type="text"
              name="name"
              placeholder={props.labelName}
              class="w-full bg-transparent border-b border-dark/30 py-2 text-sm text-dark placeholder:text-dark/40 focus:outline-none focus:border-dark"
            />
          </div>
          <div>
            <label class="block text-xs font-medium text-dark mb-1">{props.labelOrg}</label>
            <input
              type="text"
              name="organisation"
              placeholder={props.labelOrg}
              class="w-full bg-transparent border-b border-dark/30 py-2 text-sm text-dark placeholder:text-dark/40 focus:outline-none focus:border-dark"
            />
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-dark mb-1">{props.labelEmail} *</label>
          <input
            type="email"
            name="email"
            required
            placeholder={props.labelEmail}
            class="w-full bg-transparent border-b border-dark/30 py-2 text-sm text-dark placeholder:text-dark/40 focus:outline-none focus:border-dark"
          />
        </div>
        <div>
          <label class="block text-xs font-medium text-dark mb-1">{props.labelMessage} *</label>
          <textarea
            name="message"
            required
            rows="3"
            placeholder={props.labelMessage}
            class="w-full bg-transparent border-b border-dark/30 py-2 text-sm text-dark placeholder:text-dark/40 focus:outline-none focus:border-dark resize-none"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full bg-dark text-cream font-semibold tracking-widest text-sm py-4 rounded-full hover:bg-dark/80 transition-colors mt-4"
        >
          {props.submitText}
        </button>
      </form>
    </div>
  </div>
</section>
