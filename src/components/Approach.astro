---
interface Pillar {
  title: string;
  body: string;
}

interface Props {
  heading: string;
  intro: string;
  pillars: Pillar[];
  image: string;
  imageAlt: string;
}

const { heading, intro, pillars, image, imageAlt } = Astro.props;
---

<section id="enfoque" class="bg-cream py-24 px-6">
  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
    <div>
      <h2 class="text-5xl md:text-6xl font-black text-dark mb-8 leading-tight">{heading}</h2>
      <p class="text-xl font-semibold text-dark leading-snug mb-12">{intro}</p>
      <div class="space-y-8">
        {
          pillars.map((pillar) => (
            <div>
              <h3 class="text-base font-bold text-dark mb-2">{pillar.title}</h3>
              <p class="text-sm text-dark/80 leading-relaxed">{pillar.body}</p>
            </div>
          ))
        }
      </div>
    </div>
    <div class="rounded-2xl overflow-hidden">
      <img src={image} alt={imageAlt} class="w-full h-full object-cover grayscale" loading="lazy" />
    </div>
  </div>
</section>
